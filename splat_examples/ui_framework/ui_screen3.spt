;===============================================================================
;DESCRIPTION:
; Called by any task to request display of this screen.
;PARAMETERS:
;  -> Nil
;RETURNS:
; <-  Nil
;===============================================================================
UIsubScreenShowScreen3:
   LoadX          UIkScreenScreen3
   Goto           UIsubSetScreen


;===============================================================================
;DESCRIPTION:
; Entry point for this screen
;PARAMETERS:
;  -> 
;RETURNS:
; <-  
;===============================================================================
UIscreenScreen3:
   ;display static items, like headings, images and buttons.
   GoSub          UIsubDrawHeading
   #HMI           Print( "\CScreen Three" )
   #HMI           SetBounds()

   GoSub          UIsubDrawDefaults
   #HMI           SetCursor( x:0, y:3 )
   #HMI           Print( "This screen was only accessible\nfrom screen 2" )

   GoSub          UIsubDrawButtonDefaults
   #HMI           ButtonEvent2( x:-20%, y:-20%, w:20%, h:20%, t:"BACK", pf:HUEkBtnNormPF, pb:HUEkBtnNormPB, ev:UIsubSetScreenPrevious )

   GoSub          UIsubDrawDefaults


_SCR4Loop
   Pause          10
   GoIfST         UIsNewScreen,UIDoNewScreen          ;jump if there's a new screen to display

   ;we could do other UI things realted to this screen here, like displaying a changing pressure or temperature

   Goto           _SCR4Loop



