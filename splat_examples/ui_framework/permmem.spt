;<INITSEG>
;
;===============================================================================


;===============================================================================
;
;<CONSTSEG>
;
;===============================================================================
PMkVersion        #EQU  1                             ;change if items change


;===============================================================================
;
;<MEQUSEG>
;RAM storage
;
;===============================================================================
;permstore
; nil

;at a fixed location to ensure app update with new varaibles doesn't move it
PMkLength         #EQU     5                          ;length includes checksum
PMkStart          mEQU     220
;+++
;+++ insert other parameters here +++
;+++ modify PMsubLoadDefaults to set the default values ++
;+++
PMfSetTemperature mEQU     220,4                      ;for example, a target temperature

PMbChecksum       mEQU     224,1                      ;additive checksum (should be the last item)
PMkVerNumAddr     EQU   255


;===============================================================================
;
;<IOSEG>
;I/O Assignments
