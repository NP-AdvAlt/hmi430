;===============================================================================
;DESCRIPTION:
; Called at power on to configure xwire.
;PARAMETERS:
;  -> Nil
;RETURNS:
; <-  Nil
;===============================================================================
XWsubInitialise:
   XwirePhys      XWPHY_TTL
   XwireMaster    XWpMaster
   Return


