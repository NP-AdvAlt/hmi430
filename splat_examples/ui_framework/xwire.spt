;<NVEM0DIR>
;
;===============================================================================
   NVEM0                                              ;Start of non-volatile memory


;===============================================================================
;
;<NVEM0DATA>
;Non-volatile memory data
;
;===============================================================================
XWpMaster
                 ;Addr, SEXI=255,   Din,  Dout, Ain,  Aout, TXBuf,   TXLen,   RXBuf,   RXLen
   NV0Byte        0,    255,        8,    8,    0,    0,    0,       0,       0,       0  ;DR240, 8 din, 8 dout, 0 ain, 0 aout
   NV0Byte        1,    255,        4,    4,    8,    2,    0,       0,       0,       0  ;DA8, 4 din, 4 dout, 8 ain, 2 aout
   NV0Byte        255                                                                     ;table terminator



