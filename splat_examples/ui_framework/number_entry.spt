; &               #EQU  UIbShared2
NEbTextIdx        #EQU  UIbShared3                    ;shared index into NEabTextEntry
NEbMaxText        #EQU  UIbShared4                    ;maximum nof chars to enter
NEkBufLen         #EQU  7
NEabTextEntry     #EQU  UIbShared5                    ;buffer
; to              #EQU  UIbShared11


