;<TESTSEG>
;
;===============================================================================


;===============================================================================
;
;<NVEM0DIR>
;
;===============================================================================
   NVEM0                                              ;Start of non-volatile memory


;===============================================================================
;
;<NVEM0DATA>
;Non-volatile memory data
;
;===============================================================================
_BRpTimer         NV0Byte  "Timer",0
_BRpAmbient       NV0Byte  "Ambient",0
_BRpLow           NV0Byte  "Low",0
_BRpHigh          NV0Byte  "High",0

BRpMode
   NV0Ptr   _BRpTimer
   NV0Ptr   _BRpAmbient
   NV0Ptr   _BRpLow
   NV0Ptr   _BRpHigh

