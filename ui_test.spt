; ui_test.spt -- mapping verification (2x 4x4px buttons)
uiTask:
    YieldTask
    YieldTask
uiTask_draw:
    GoSub drawButtons
    YieldTask
    YieldTask
uiTask_idle:
    Pause 500
    GoTo uiTask_idle

drawButtons:
    #HMI SetColours(f:'FF000000, b:'FFFFFFFF)
    #HMI Reset(b:0)
    #HMI ButtonEvent2(id:0, x:98px, y:98px, w:4px, h:4px, t:" ", rb:'FFFFFFFF, pb:'FF000000, ev:onPress)
    #HMI ButtonEvent2(id:1, x:408px, y:200px, w:4px, h:4px, t:" ", rb:'FFFFFFFF, pb:'FF000000, ev:onPress)
    Return

onPress:
    Return
